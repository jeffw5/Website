<P class=3DMsoNormal style=3D"TEXT-ALIGN: center" =
align=3Dcenter><I><SPAN=20
style=3D"FONT-SIZE: 12pt; mso-bidi-font-size: 10.0pt"><A=20
href=3D"mailto:geerts@aisvillage.com">geerts@aisvillage.com</A>;=20
302/831-6413<U7:P></U7:P></SPAN></I><SPAN style=3D"FONT-SIZE: 12pt">=20
